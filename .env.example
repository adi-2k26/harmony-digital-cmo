PORT=4000
FASTAPI_PORT=8001
DATABASE_URL=postgresql://harmony:harmony@localhost:5432/harmony_cmo
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
TOKEN_DAILY_CAP=250000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ENABLE_BACKGROUND_JOBS=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
# Next.js Route Handler timeout (ms) for POST /api/agents/:id/run-full-analysis.
RUN_FULL_ANALYSIS_TIMEOUT_MS=280000
# Optional: server-side only — where Next.js proxies module deep-dive (Docker/hostnames). Defaults to NEXT_PUBLIC_API_BASE_URL.
# API_INTERNAL_URL=http://host.docker.internal:8001
# Browser calls FastAPI directly from the Next app origin — include every dev port you use (e.g. 3001 if 3000 is busy):
# FASTAPI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Next.js loads NEXT_PUBLIC_* from apps/web/.env.local (not from repo root .env). Set the same FastAPI URL there for the UI proxy routes.
# Vercel tip: if deploying FastAPI Python function in the same project, you can leave NEXT_PUBLIC_API_BASE_URL unset and
# rely on vercel.json rewrite /harmony-api/* -> /api/harmony/*.
# Copy to .env for local dev. FastAPI loads this file from the repo root automatically.
# OPENAI_API_KEY is used for POST /agents/{id}/deep-dive and GET /health/openai?probe=true
